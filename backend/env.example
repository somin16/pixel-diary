# 각자 키를 적으세요 깃허브에는 보안상 올릴 수 없습니다

# [Django Settings]
SECRET_KEY=django-insecure-your-unique-key #장고 시크릿 키 넣으세요
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# [Supabase Common]
SUPABASE_URL=https://your-project-id.supabase.co # 슈파베이스 프로젝트 아이디 your-project-id 부분에 넣으세요
SUPABASE_ANON_KEY=sb_로 시작하는 키 넣으세요

# [중요] AI 서버가 DB/스토리지에 직접 '쓰기'를 하려면 Service Role Key가 필요합니다.

# 서비스롤 (secret) 넣으세요
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# [Supabase Database] 
# AI가 생성한 이미지 URL과 일기 텍스트를 저장할 때 필요합니다.
DB_HOST=db.your-project-id.supabase.co # 슈파베이스 프로젝트 아이디 your-project-id에 넣으세요
DB_NAME=postgres
DB_USER=postgres
DB_PORT=5432
DB_PASSWORD=your_supabase_db_password # DB 패스워드 넣으세요

# [AI Model Settings]
# 로컬에 저장된 모델 경로가 있다면 관리하기 편하게 추가합니다.
AI_MODEL_PATH=./models/stable-diffusion-v1-5